                  { tab: "Design", refs: "Ball et al. (2017), Israel et al. (2005), Creswell & Plano Clark (2017)" },
                  { tab: "Evaluation", refs: "Glasgow & Estabrooks (2018), Moore et al. (2015), Chazdon et al. (2017)" },
                  { tab: "Measures", refs: "Amouzandeh et al. (2019), Begley et al. (2019), Hawthorne (2006), Lobo et al. (2022), Bickel et al. (2000)" },
                ].map((row, i) => (
                  <div key={i} style={{ display: "flex", gap: 12, marginBottom: i < 3 ? 8 : 0, fontSize: 12 }}>
                    <div style={{ opacity: 0.4, flexShrink: 0, width: 72 }}>{row.tab}</div>
                    <div style={{ opacity: 0.75, lineHeight: 1.55 }}>{row.refs}</div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
